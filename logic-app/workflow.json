{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "logicAppName": { "type": "string", "defaultValue": "silentpulse-logic-app" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" }
  },
  "resources": [
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('logicAppName')]",
      "location": "[parameters('location')]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "triggers": {
            "manual": {
              "type": "Request",
              "kind": "Http",
              "inputs": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "phone": { "type": "string" },
                    "lat": { "type": "string" },
                    "lng": { "type": "string" },
                    "maps_url": { "type": "string" },
                    "timestamp": { "type": "string" },
                    "accuracy": { "type": "string" }
                  }
                }
              }
            }
          },
          "actions": {
            "Call_AI_Agent": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://silentpulse-function.azurewebsites.net/api/agent",
                "body": {
                  "name": "@triggerBody()?['name']",
                  "phone": "@triggerBody()?['phone']",
                  "lat": "@triggerBody()?['lat']",
                  "lng": "@triggerBody()?['lng']",
                  "maps_url": "@triggerBody()?['maps_url']",
                  "timestamp": "@triggerBody()?['timestamp']"
                }
              }
            },
            "Response": {
              "type": "Response",
              "inputs": {
                "statusCode": 200,
                "body": { "status": "Alert processed by AI Agent" }
              },
              "runAfter": { "Call_AI_Agent": ["Succeeded"] }
            }
          }
        }
      }
    }
  ]
}
